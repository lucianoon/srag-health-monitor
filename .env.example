# SRAG Health Monitor environment configuration
# Copy this file to .env and replace the placeholder values.

# Required to run the report orchestrator with OpenAI models.
OPENAI_API_KEY=your-openai-api-key-here

# Optional API key for protected HTTP endpoints. Leave empty for local dev.
SRAG_API_KEY=

# Optional path to the SQLite database. Defaults to ./data/srag.db.
SRAG_DB_PATH=./data/srag.db

# Optional runtime paths.
SRAG_DATA_DIR=./data
SRAG_JOBS_DB_PATH=./data/jobs.db
SRAG_OUTPUT_DIR=./outputs/reports
SRAG_LOG_DIR=./outputs/logs
SRAG_MODEL=gpt-4.1-mini

# Optional SUS/OpenDATASUS ingestion source.
# Use the CSV resource URL published in the official dataset page.
SRAG_SUS_DATA_URL=
SRAG_SUS_INGEST_NROWS=
